{
  "manifest_version": 3,
  "name": "New Tab Shortcuts",
  "version": "1.0",
  "description": "快速将当前网页添加到新标签页快捷导航",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
